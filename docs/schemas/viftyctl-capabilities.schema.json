{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/viftyctl-capabilities.schema.json",
  "title": "viftyctl capabilities --json report",
  "description": "Machine-readable capabilities report emitted by viftyctl capabilities --json. Agents should use this payload to discover supported commands, workloads, policy limits, and exit-code meanings instead of hardcoding them.",
  "type": "object",
  "required": [
    "schemaVersion",
    "commands",
    "workloads",
    "schemas",
    "schemaResources",
    "schemaIDs",
    "policy",
    "policySource",
    "daemonStatusAvailable",
    "agentControlStatusError",
    "supportsForceRetry",
    "runLifecycle",
    "directControlLifecycle",
    "metadataLimits",
    "exitCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "enum": [
          "status",
          "capabilities",
          "diagnose",
          "audit",
          "prepare",
          "restore-auto",
          "run"
        ]
      }
    },
    "workloads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workload"
      }
    },
    "schemas": {
      "$ref": "#/$defs/schemaPathReferences"
    },
    "schemaResources": {
      "$ref": "#/$defs/schemaResourceReferences"
    },
    "schemaIDs": {
      "$ref": "#/$defs/schemaIDReferences"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "policySource": {
      "enum": [
        "daemonStatus",
        "fallbackUnavailable"
      ]
    },
    "daemonStatusAvailable": {
      "type": "boolean"
    },
    "agentControlStatusError": {
      "type": [
        "string",
        "null"
      ]
    },
    "supportsForceRetry": {
      "type": "boolean",
      "description": "True when viftyctl run --force supports a supervised one-time wait for retryAfterSeconds and retry after a rate-limited prepare. Consumers reading legacy payloads without this field should treat force retry as unsupported."
    },
    "runLifecycle": {
      "$ref": "#/$defs/runLifecycle"
    },
    "directControlLifecycle": {
      "$ref": "#/$defs/directControlLifecycle"
    },
    "metadataLimits": {
      "$ref": "#/$defs/metadataLimits"
    },
    "exitCodes": {
      "$ref": "#/$defs/exitCodes"
    }
  },
  "$defs": {
    "workload": {
      "enum": [
        "build",
        "test",
        "render",
        "localModel",
        "custom"
      ]
    },
    "schemaPathReferences": {
      "type": "object",
      "required": [
        "capabilities",
        "audit",
        "diagnose",
        "status",
        "commandError"
      ],
      "properties": {
        "capabilities": {
          "const": "docs/schemas/viftyctl-capabilities.schema.json"
        },
        "audit": {
          "const": "docs/schemas/viftyctl-audit.schema.json"
        },
        "diagnose": {
          "const": "docs/schemas/viftyctl-diagnose.schema.json"
        },
        "status": {
          "const": "docs/schemas/viftyctl-status.schema.json"
        },
        "commandError": {
          "const": "docs/schemas/viftyctl-command-error.schema.json"
        }
      }
    },
    "schemaResourceReferences": {
      "type": "object",
      "required": [
        "capabilities",
        "audit",
        "diagnose",
        "status",
        "commandError"
      ],
      "properties": {
        "capabilities": {
          "const": "Contents/Resources/schemas/viftyctl-capabilities.schema.json"
        },
        "audit": {
          "const": "Contents/Resources/schemas/viftyctl-audit.schema.json"
        },
        "diagnose": {
          "const": "Contents/Resources/schemas/viftyctl-diagnose.schema.json"
        },
        "status": {
          "const": "Contents/Resources/schemas/viftyctl-status.schema.json"
        },
        "commandError": {
          "const": "Contents/Resources/schemas/viftyctl-command-error.schema.json"
        }
      }
    },
    "schemaIDReferences": {
      "type": "object",
      "required": [
        "capabilities",
        "audit",
        "diagnose",
        "status",
        "commandError"
      ],
      "properties": {
        "capabilities": {
          "const": "https://vifty.local/schemas/viftyctl-capabilities.schema.json"
        },
        "audit": {
          "const": "https://vifty.local/schemas/viftyctl-audit.schema.json"
        },
        "diagnose": {
          "const": "https://vifty.local/schemas/viftyctl-diagnose.schema.json"
        },
        "status": {
          "const": "https://vifty.local/schemas/viftyctl-status.schema.json"
        },
        "commandError": {
          "const": "https://vifty.local/schemas/viftyctl-command-error.schema.json"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "enabled",
        "minimumAgentRPMPercent",
        "maximumAllowedRPMPercent",
        "maxDurationSeconds",
        "prepareCooldownSeconds"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minimumAgentRPMPercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "maximumAllowedRPMPercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "maxDurationSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "prepareCooldownSeconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "exitCodes": {
      "type": "object",
      "required": [
        "success",
        "commandFailure",
        "usage",
        "unavailable",
        "blockedReadiness"
      ],
      "properties": {
        "success": {
          "type": "integer"
        },
        "commandFailure": {
          "type": "integer"
        },
        "usage": {
          "type": "integer"
        },
        "unavailable": {
          "type": "integer"
        },
        "blockedReadiness": {
          "type": "integer"
        }
      }
    },
    "runLifecycle": {
      "type": "object",
      "description": "Machine-readable viftyctl run lifecycle guarantees that agents can depend on before deciding how much wrapper logic to add around a workload. Consumers reading legacy payloads without this object should treat every lifecycle guarantee as unsupported.",
      "required": [
        "childCommandPreflightBeforeCooling",
        "signalsForwardedToChild",
        "autoRestoreAfterChildExit",
        "structuredPreChildFailures",
        "cleanupStateReportedOnLaunchFailure"
      ],
      "properties": {
        "childCommandPreflightBeforeCooling": {
          "type": "boolean",
          "description": "True when viftyctl run resolves and validates the child executable before preparing a cooling lease."
        },
        "signalsForwardedToChild": {
          "type": "array",
          "items": {
            "enum": [
              "INT",
              "TERM",
              "HUP"
            ]
          },
          "uniqueItems": true
        },
        "autoRestoreAfterChildExit": {
          "type": "boolean",
          "description": "True when viftyctl run attempts to restore Auto after child launch failure, normal child exit, or handled signal exit."
        },
        "structuredPreChildFailures": {
          "type": "boolean",
          "description": "True when viftyctl run --json emits structured command-error reports before the child process starts."
        },
        "cleanupStateReportedOnLaunchFailure": {
          "type": "boolean",
          "description": "True when launch failures after a prepared lease report whether cleanup was attempted and whether Auto restore succeeded."
        }
      }
    },
    "directControlLifecycle": {
      "type": "object",
      "description": "Machine-readable direct prepare/restore lifecycle contract. Agents should prefer viftyctl run for single child workloads and use this object before deciding whether direct prepare/restore is safe for a supervised multi-step workflow.",
      "required": [
        "prepareUsesIdempotencyKey",
        "restoreAutoAcceptsIdempotencyKey",
        "restoreAutoScopedByIdempotencyKey",
        "preferRunForSingleChildWorkloads"
      ],
      "properties": {
        "prepareUsesIdempotencyKey": {
          "type": "boolean",
          "description": "True when direct prepare/run requests carry idempotency keys so repeated prepare calls can return the existing active lease instead of reapplying cooling."
        },
        "restoreAutoAcceptsIdempotencyKey": {
          "type": "boolean",
          "description": "False when restore-auto rejects --idempotency-key instead of accepting a no-op scoped option."
        },
        "restoreAutoScopedByIdempotencyKey": {
          "type": "boolean",
          "description": "False when restore-auto restores the active supervised lease rather than selecting a lease by idempotency key."
        },
        "preferRunForSingleChildWorkloads": {
          "type": "boolean",
          "description": "True when agents should prefer viftyctl run for ordinary single child workloads so prepare, child execution, signal forwarding, and Auto restore remain one lifecycle."
        }
      }
    },
    "metadataLimits": {
      "type": "object",
      "description": "Machine-readable prepare/run metadata limits. Agents should use these values before constructing reason or idempotency-key strings instead of hardcoding local guesses.",
      "required": [
        "maximumReasonLength",
        "maximumIdempotencyKeyLength"
      ],
      "properties": {
        "maximumReasonLength": {
          "type": "integer",
          "const": 512,
          "description": "Maximum number of characters accepted for prepare/run reason metadata after trimming."
        },
        "maximumIdempotencyKeyLength": {
          "type": "integer",
          "const": 256,
          "description": "Maximum number of characters accepted for prepare/run idempotency-key metadata after trimming."
        }
      }
    }
  }
}
