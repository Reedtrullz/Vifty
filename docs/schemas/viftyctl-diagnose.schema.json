{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/viftyctl-diagnose.schema.json",
  "title": "viftyctl diagnose --json readiness report",
  "description": "Machine-readable readiness report emitted by viftyctl diagnose --json. Local agents should treat state=blocked, safeToRequestCooling=false, daemonControlPathReady=false, manualControlActive=true, daemonRuntime.matchRequired=true with daemonRuntime.matchesExpectedDaemon not true, or non-empty coolingBlockerIDs as a hard stop before requesting Vifty cooling.",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "state",
    "recommendedAgentAction",
    "recommendedRecoveryAction",
    "safeToRequestCooling",
    "daemonControlPathReady",
    "manualControlActive",
    "daemonRuntime",
    "modelIdentifier",
    "isAppleSilicon",
    "isMacBookPro",
    "thermalPressure",
    "fanCount",
    "controllableFanCount",
    "temperatureSensorCount",
    "fans",
    "temperatureSensors",
    "agentControl",
    "checks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "description": "Swift JSONEncoder date value emitted by the CLI.",
      "type": "number"
    },
    "state": {
      "enum": [
        "ready",
        "degraded",
        "blocked"
      ]
    },
    "recommendedAgentAction": {
      "enum": [
        "requestCooling",
        "requestCoolingWithCaution",
        "restoreAutoBeforeRequestingCooling",
        "doNotRequestCooling"
      ]
    },
    "recommendedRecoveryAction": {
      "description": "Machine-readable operator or agent follow-up when readiness is blocked or requires cleanup. Use this field instead of parsing check messages.",
      "enum": [
        "none",
        "repairHelper",
        "restoreAutoBeforeRetry",
        "backOffWorkload",
        "inspectPolicy",
        "collectHardwareEvidence"
      ]
    },
    "recoverySteps": {
      "description": "Ordered human-safe recovery guidance for the recommendedRecoveryAction. Agents may show these steps directly, but must still use the safety fields as authorization gates.",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "operatorRecoveryCommands": {
      "description": "Optional local operator commands that can be shown to a human for explicit recovery actions such as helper repair. These commands are not cooling authorization and must not be run automatically by agents.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/operatorRecoveryCommand"
      },
      "uniqueItems": true
    },
    "safeToRequestCooling": {
      "type": "boolean"
    },
    "daemonControlPathReady": {
      "description": "True only when diagnose reached the daemon-backed snapshot and agent-control status paths required before preparing bounded cooling. If false, agents must repair the helper instead of inferring write readiness from fallback telemetry.",
      "type": "boolean"
    },
    "manualControlActive": {
      "description": "True when Vifty's local manual-control marker is present. Agents must restore Auto or ask the user to switch Vifty to Auto before requesting cooling.",
      "type": "boolean"
    },
    "failedCheckIDs": {
      "description": "Ordered readiness check IDs whose checks failed in this report. This mirrors checks[] without requiring agents to parse messages.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/readinessCheckID"
      }
    },
    "coolingBlockerIDs": {
      "description": "Ordered failed check IDs that block a new cooling request. Warning-only caution states may have failedCheckIDs without coolingBlockerIDs.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/readinessCheckID"
      }
    },
    "appPreferences": {
      "description": "Read-only snapshot of local Vifty app preferences useful for diagnosing whether a saved default startup mode may reassert manual control. This is not a cooling authorization.",
      "$ref": "#/$defs/appPreferencesDiagnostic"
    },
    "daemonRuntime": {
      "description": "Read-only comparison between the installed privileged helper daemon and the daemon expected by this viftyctl build. When matchRequired is true, agents must require matchesExpectedDaemon=true before requesting cooling.",
      "$ref": "#/$defs/daemonRuntimeDiagnostic"
    },
    "modelIdentifier": {
      "type": "string"
    },
    "isAppleSilicon": {
      "type": "boolean"
    },
    "isMacBookPro": {
      "type": "boolean"
    },
    "thermalPressure": {
      "enum": [
        "nominal",
        "fair",
        "serious",
        "critical",
        "unknown"
      ]
    },
    "fanCount": {
      "type": "integer",
      "minimum": 0
    },
    "controllableFanCount": {
      "type": "integer",
      "minimum": 0
    },
    "temperatureSensorCount": {
      "type": "integer",
      "minimum": 0
    },
    "highestTemperatureCelsius": {
      "type": [
        "number",
        "null"
      ]
    },
    "fans": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fanReport"
      }
    },
    "temperatureSensors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/temperatureSensorReport"
      }
    },
    "agentControl": {
      "$ref": "#/$defs/agentControlStatus"
    },
    "daemonSnapshotError": {
      "type": [
        "string",
        "null"
      ]
    },
    "agentControlStatusError": {
      "type": [
        "string",
        "null"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/readinessCheck"
      }
    }
  },
  "$defs": {
    "appPreferencesDiagnostic": {
      "type": "object",
      "required": [
        "startupMode",
        "startupModeSource",
        "readError"
      ],
      "properties": {
        "startupMode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Auto",
            "Curve",
            "Fixed",
            null
          ]
        },
        "startupModeSource": {
          "enum": [
            "persisted",
            "defaultMissingFile",
            "defaultMissingKey",
            "unreadable",
            "unavailable"
          ]
        },
        "readError": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "daemonRuntimeDiagnostic": {
      "type": "object",
      "required": [
        "installedDaemonPath",
        "installedDaemonPresent",
        "installedDaemonSHA256",
        "expectedDaemonPath",
        "expectedDaemonPresent",
        "expectedDaemonSHA256",
        "matchesExpectedDaemon",
        "matchRequired"
      ],
      "properties": {
        "installedDaemonPath": {
          "type": "string"
        },
        "installedDaemonPresent": {
          "type": "boolean"
        },
        "installedDaemonSHA256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "expectedDaemonPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "expectedDaemonPresent": {
          "type": "boolean"
        },
        "expectedDaemonSHA256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "matchesExpectedDaemon": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "matchRequired": {
          "type": "boolean"
        }
      }
    },
    "operatorRecoveryCommand": {
      "type": "object",
      "required": [
        "id",
        "title",
        "command",
        "workingDirectoryHint",
        "requiresUserApproval",
        "safeForAgentsToRunAutomatically",
        "notes"
      ],
      "properties": {
        "id": {
          "enum": [
            "repair-helper-current-app"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "workingDirectoryHint": {
          "type": "string",
          "minLength": 1
        },
        "requiresUserApproval": {
          "type": "boolean"
        },
        "safeForAgentsToRunAutomatically": {
          "const": false
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "fanReport": {
      "type": "object",
      "required": [
        "id",
        "name",
        "currentRPM",
        "minimumRPM",
        "maximumRPM",
        "controllable"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "type": "string"
        },
        "currentRPM": {
          "type": "integer",
          "minimum": 0
        },
        "minimumRPM": {
          "type": "integer",
          "minimum": 0
        },
        "maximumRPM": {
          "type": "integer",
          "minimum": 0
        },
        "controllable": {
          "type": "boolean"
        },
        "hardwareMode": {
          "type": [
            "string",
            "null"
          ]
        },
        "hardwareModeRawValue": {
          "type": [
            "integer",
            "null"
          ]
        },
        "hardwareModeKey": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^F[0-9](Md|md)$"
        },
        "targetRPM": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "temperatureSensorReport": {
      "type": "object",
      "required": [
        "id",
        "name",
        "celsius",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "celsius": {
          "type": "number"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "readinessCheck": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "passed",
        "message"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/readinessCheckID"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "readinessCheckID": {
      "enum": [
        "daemonSnapshotAvailable",
        "agentControlStatusAvailable",
        "daemonControlPathReady",
        "daemonRuntimeMatchesExpected",
        "supportedHardware",
        "agentControlEnabled",
        "temperatureSensorsPresent",
        "controllableFansPresent",
        "fanIDsValid",
        "fanIDsUnique",
        "fanRangesValid",
        "thermalPressureSafe",
        "activeLeaseClear",
        "manualControlClear",
        "fanModeTelemetry"
      ]
    },
    "agentControlStatus": {
      "type": "object",
      "required": [
        "enabled",
        "activeLease",
        "lastDecision",
        "lastErrorCode",
        "policy"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "activeLease": {
          "type": [
            "object",
            "null"
          ]
        },
        "lastDecision": {
          "type": [
            "object",
            "null"
          ]
        },
        "lastErrorCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "policy": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  }
}
