{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/viftyctl-agent-rule.schema.json",
  "title": "viftyctl agent-rule --json report",
  "description": "Machine-readable safe local agent/build/test cooling rule emitted by viftyctl agent-rule --json. This payload is read-only guidance for agents and must not be treated as cooling authorization; agents still need capabilities and diagnose readiness before running guarded workloads.",
  "type": "object",
  "required": [
    "schemaVersion",
    "schemaID",
    "command",
    "generatedAt",
    "rule",
    "viftyctlCommand",
    "capabilitiesCommand",
    "diagnoseCommand",
    "guardedRunDecisionSchemaID",
    "guardedRunJSONMarkers",
    "agentCoolingEvidenceCommand",
    "agentCoolingPreflightEvidenceCommand",
    "guardedRunCommand",
    "guardedRunPreflightCommand",
    "schemaRequirements",
    "safetyRequirements",
    "forbiddenActions",
    "workloadTemplateIDs"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/viftyctl-agent-rule.schema.json"
    },
    "command": {
      "const": "agent-rule"
    },
    "generatedAt": {
      "type": "number"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "viftyctlCommand": {
      "type": "string",
      "minLength": 1
    },
    "capabilitiesCommand": {
      "type": "string",
      "minLength": 1
    },
    "diagnoseCommand": {
      "type": "string",
      "minLength": 1
    },
    "strictDiagnoseCommand": {
      "description": "Optional shell-safe diagnose gate. It prints the same diagnose JSON as diagnoseCommand but exits with blocked-readiness code 75 unless the report authorizes a new cooling request.",
      "type": "string",
      "minLength": 1
    },
    "repairHelperRecoveryActions": {
      "description": "Optional human-safe recovery actions agents can show when diagnose or command-error JSON reports recommendedRecoveryAction: repairHelper. These actions are recovery guidance only, not permission to request cooling.",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "Open Vifty and use Repair/Reinstall Helper, then approve Login Items if macOS asks."
          }
        },
        {
          "contains": {
            "const": "In a source checkout, run make repair-helper for the same explicit administrator-approved LaunchDaemon repair."
          }
        },
        {
          "contains": {
            "const": "After repair, rerun diagnose --json and require safe readiness before requesting cooling."
          }
        }
      ]
    },
    "guardedRunDecisionSchemaID": {
      "const": "https://vifty.local/schemas/guarded-run-decision.schema.json"
    },
    "guardedRunJSONMarkers": {
      "type": "object",
      "required": [
        "capabilities",
        "diagnose",
        "decision"
      ],
      "properties": {
        "capabilities": {
          "$ref": "#/$defs/markerPair"
        },
        "diagnose": {
          "$ref": "#/$defs/markerPair"
        },
        "decision": {
          "$ref": "#/$defs/markerPair"
        }
      },
      "additionalProperties": false
    },
    "guardedRunCommand": {
      "type": "string",
      "minLength": 1
    },
    "guardedRunPreflightCommand": {
      "type": "string",
      "minLength": 1
    },
    "agentCoolingEvidenceCommand": {
      "description": "Read-only support bundle command for helper, readiness, or guarded-run failures. This command collects diagnostics and evidence only; it must not request cooling or write fan state.",
      "type": "string",
      "minLength": 1
    },
    "agentCoolingPreflightEvidenceCommand": {
      "description": "Read-only support bundle command that also captures a guarded-run --preflight-only exact-workload envelope. This command must not request cooling or launch the child workload.",
      "type": "string",
      "minLength": 1
    },
    "schemaRequirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "schemaVersion == 1"
          }
        },
        {
          "contains": {
            "const": "schemaIDs.capabilities"
          }
        },
        {
          "contains": {
            "const": "schemaIDs.diagnose"
          }
        },
        {
          "contains": {
            "const": "schemaIDs.commandError"
          }
        },
        {
          "contains": {
            "const": "schemaIDs.run"
          }
        },
        {
          "contains": {
            "const": "schemaIDs.agentRule"
          }
        },
        {
          "contains": {
            "const": "guardedRunDecisionSchemaID"
          }
        },
        {
          "contains": {
            "const": "guardedRunJSONMarkers"
          }
        },
        {
          "contains": {
            "const": "agentCoolingEvidenceCommand"
          }
        },
        {
          "contains": {
            "const": "agentCoolingPreflightEvidenceCommand"
          }
        },
        {
          "contains": {
            "const": "wrapperResources"
          }
        },
        {
          "contains": {
            "const": "workloadTemplates"
          }
        },
        {
          "contains": {
            "const": "runLifecycle.resolvedChildExecutableReported == true"
          }
        }
      ]
    },
    "safetyRequirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "policyStatusAvailable == true"
          }
        },
        {
          "contains": {
            "const": "policy.enabled == true"
          }
        },
        {
          "contains": {
            "const": "safeToRequestCooling == true"
          }
        },
        {
          "contains": {
            "const": "daemonControlPathReady == true"
          }
        },
        {
          "contains": {
            "const": "manualControlActive == false"
          }
        },
        {
          "contains": {
            "const": "daemonRuntime.matchRequired != true || daemonRuntime.matchesExpectedDaemon == true"
          }
        },
        {
          "contains": {
            "const": "coolingBlockerIDs is empty"
          }
        }
      ]
    },
    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "ViftyHelper setFixed"
          }
        },
        {
          "contains": {
            "const": "ViftyHelper auto"
          }
        },
        {
          "contains": {
            "const": "sudo"
          }
        },
        {
          "contains": {
            "const": "raw SMC tools"
          }
        },
        {
          "contains": {
            "const": "direct fan RPM writes"
          }
        },
        {
          "contains": {
            "const": "unguarded viftyctl prepare"
          }
        }
      ]
    },
    "workloadTemplateIDs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "swift-test"
          }
        },
        {
          "contains": {
            "const": "swift-release-build"
          }
        },
        {
          "contains": {
            "const": "xcode-build"
          }
        },
        {
          "contains": {
            "const": "xcode-test"
          }
        },
        {
          "contains": {
            "const": "make-build"
          }
        },
        {
          "contains": {
            "const": "make-test"
          }
        },
        {
          "contains": {
            "const": "make-verify"
          }
        },
        {
          "contains": {
            "const": "npm-build"
          }
        },
        {
          "contains": {
            "const": "npm-test"
          }
        },
        {
          "contains": {
            "const": "pnpm-build"
          }
        },
        {
          "contains": {
            "const": "pnpm-test"
          }
        },
        {
          "contains": {
            "const": "bun-build"
          }
        },
        {
          "contains": {
            "const": "bun-test"
          }
        },
        {
          "contains": {
            "const": "go-build"
          }
        },
        {
          "contains": {
            "const": "go-test"
          }
        },
        {
          "contains": {
            "const": "cargo-build"
          }
        },
        {
          "contains": {
            "const": "cargo-test"
          }
        },
        {
          "contains": {
            "const": "uv-build"
          }
        },
        {
          "contains": {
            "const": "uv-test"
          }
        },
        {
          "contains": {
            "const": "pytest"
          }
        },
        {
          "contains": {
            "const": "local-model-template"
          }
        },
        {
          "contains": {
            "const": "custom-workload-template"
          }
        }
      ]
    }
  },
  "$defs": {
    "markerPair": {
      "type": "object",
      "required": [
        "begin",
        "end"
      ],
      "properties": {
        "begin": {
          "type": "string",
          "pattern": "^guarded-run: BEGIN_VIFTY_[A-Z_]+_JSON$"
        },
        "end": {
          "type": "string",
          "pattern": "^guarded-run: END_VIFTY_[A-Z_]+_JSON$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
