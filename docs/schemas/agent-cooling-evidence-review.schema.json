{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json",
  "title": "Vifty agent cooling evidence review",
  "description": "Machine-readable pass/fail summary written by scripts/review-agent-cooling-evidence.sh after reviewing a read-only agent/helper support bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemaID",
    "generatedAtUTC",
    "bundlePath",
    "status",
    "readOnly",
    "coolingCommandsRun",
    "commandsReviewed",
    "failures",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "bundlePath": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "readOnly": {
      "const": true
    },
    "coolingCommandsRun": {
      "const": false
    },
    "commandsReviewed": {
      "type": "integer",
      "minimum": 0
    },
    "failures": {
      "$ref": "#/$defs/stringArray"
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
