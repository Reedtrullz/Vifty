{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json",
  "title": "Vifty agent cooling evidence review",
  "description": "Machine-readable pass/fail summary written by scripts/review-agent-cooling-evidence.sh after reviewing a read-only agent/helper support bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemaID",
    "generatedAtUTC",
    "bundlePath",
    "status",
    "readOnly",
    "coolingCommandsRun",
    "commandsReviewed",
    "diagnoseDecision",
    "failures",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "bundlePath": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "readOnly": {
      "const": true
    },
    "coolingCommandsRun": {
      "const": false
    },
    "commandsReviewed": {
      "type": "integer",
      "minimum": 0
    },
    "diagnoseDecision": {
      "$ref": "#/$defs/diagnoseDecision"
    },
    "failures": {
      "$ref": "#/$defs/stringArray"
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "diagnoseDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitStatus",
        "state",
        "recommendedAgentAction",
        "recommendedRecoveryAction",
        "safeToRequestCooling",
        "daemonControlPathReady"
      ],
      "properties": {
        "exitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ready",
            "degraded",
            "blocked",
            null
          ]
        },
        "recommendedAgentAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "requestCooling",
            "requestCoolingWithCaution",
            "restoreAutoBeforeRequestingCooling",
            "doNotRequestCooling",
            null
          ]
        },
        "recommendedRecoveryAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "none",
            "repairHelper",
            "restoreAutoBeforeRetry",
            "backOffWorkload",
            "inspectPolicy",
            "collectHardwareEvidence",
            null
          ]
        },
        "safeToRequestCooling": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "daemonControlPathReady": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
