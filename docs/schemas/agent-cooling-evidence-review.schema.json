{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json",
  "title": "Vifty agent cooling evidence review",
  "description": "Machine-readable pass/fail summary written by scripts/review-agent-cooling-evidence.sh after reviewing a read-only agent/helper support bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemaID",
    "generatedAtUTC",
    "bundlePath",
    "status",
    "readOnly",
    "coolingCommandsRun",
    "commandsReviewed",
    "diagnoseDecision",
    "capabilitiesDecision",
    "appInfo",
    "guardedRunDecision",
    "acceptedCommandErrors",
    "failures",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/agent-cooling-evidence-review.schema.json"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "bundlePath": {
      "type": "string",
      "description": "Share-safe evidence bundle directory name, not an absolute local filesystem path."
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "readOnly": {
      "const": true
    },
    "coolingCommandsRun": {
      "const": false
    },
    "commandsReviewed": {
      "type": "integer",
      "minimum": 0
    },
    "diagnoseDecision": {
      "$ref": "#/$defs/diagnoseDecision"
    },
    "capabilitiesDecision": {
      "$ref": "#/$defs/capabilitiesDecision"
    },
    "appInfo": {
      "$ref": "#/$defs/appInfo"
    },
    "guardedRunDecision": {
      "$ref": "#/$defs/guardedRunDecision"
    },
    "acceptedCommandErrors": {
      "description": "Bundle command names whose structured command-error JSON was accepted as read-only helper-unreachable evidence because diagnose reported blocked readiness and repairHelper.",
      "$ref": "#/$defs/stringArray"
    },
    "failures": {
      "$ref": "#/$defs/stringArray"
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "appInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitStatus",
        "bundleIdentifier",
        "shortVersion",
        "bundleVersion"
      ],
      "properties": {
        "exitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "bundleIdentifier": {
          "type": [
            "string",
            "null"
          ]
        },
        "shortVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "bundleVersion": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capabilitiesDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitStatus",
        "schemaVersion",
        "capabilitiesSchemaID",
        "diagnoseSchemaID",
        "commandErrorSchemaID",
        "runSchemaID",
        "daemonStatusAvailable",
        "policySource",
        "policyStatusAvailable",
        "policyEnabled",
        "supportsRunCommand",
        "supportsForceRetry",
        "runLifecycleSafe",
        "directControlLifecycleSafe",
        "metadataLimitsPresent",
        "unavailableExitCode"
      ],
      "properties": {
        "exitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "schemaVersion": {
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            1,
            null
          ]
        },
        "capabilitiesSchemaID": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "https://vifty.local/schemas/viftyctl-capabilities.schema.json",
            null
          ]
        },
        "diagnoseSchemaID": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "https://vifty.local/schemas/viftyctl-diagnose.schema.json",
            null
          ]
        },
        "commandErrorSchemaID": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "https://vifty.local/schemas/viftyctl-command-error.schema.json",
            null
          ]
        },
        "runSchemaID": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "https://vifty.local/schemas/viftyctl-run.schema.json",
            null
          ]
        },
        "daemonStatusAvailable": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "policySource": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "daemonStatus",
            "fallbackUnavailable",
            null
          ]
        },
        "policyStatusAvailable": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "policyEnabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "supportsRunCommand": {
          "type": "boolean"
        },
        "supportsForceRetry": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "runLifecycleSafe": {
          "type": "boolean"
        },
        "directControlLifecycleSafe": {
          "type": "boolean"
        },
        "metadataLimitsPresent": {
          "type": "boolean"
        },
        "unavailableExitCode": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "guardedRunDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "sourceFile",
        "schemaVersion",
        "schemaID",
        "safeToProceed",
        "coolingRequested",
        "uncooledFallbackRequested",
        "uncooledFallbackAllowed",
        "decisionReason",
        "exitCode",
        "message",
        "recommendedAgentAction",
        "recommendedRecoveryAction",
        "recoverySteps",
        "operatorRecoveryCommands",
        "diagnoseState",
        "safeToRequestCooling",
        "daemonControlPathReady",
        "manualControlActive",
        "startupMode",
        "daemonRuntime",
        "failedCheckIDs",
        "coolingBlockerIDs",
        "requestedWorkload",
        "requestedDuration",
        "requestedMaxRPMPercent",
        "reasonCharacterCount",
        "childCommandName",
        "childCommandKind",
        "childArgumentCount"
      ],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "sourceFile": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "guarded-run-stderr.txt",
            null
          ]
        },
        "schemaVersion": {
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            1,
            null
          ]
        },
        "schemaID": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "https://vifty.local/schemas/guarded-run-decision.schema.json",
            null
          ]
        },
        "safeToProceed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "coolingRequested": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "uncooledFallbackRequested": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "uncooledFallbackAllowed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "decisionReason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "readinessBlocked",
            "safeToRequestCoolingFalse",
            "daemonControlPathNotReady",
            "manualControlActive",
            "daemonRuntimeMismatch",
            "coolingBlockersPresent",
            "recoveryActionBlocksUncooledFallback",
            "preflightReady",
            "uncooledFallbackAllowed",
            "unknownNoCoolingDecision",
            null
          ]
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendedAgentAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "requestCooling",
            "requestCoolingWithCaution",
            "restoreAutoBeforeRequestingCooling",
            "doNotRequestCooling",
            null
          ]
        },
        "recommendedRecoveryAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "none",
            "repairHelper",
            "restoreAutoBeforeRetry",
            "backOffWorkload",
            "inspectPolicy",
            "collectHardwareEvidence",
            null
          ]
        },
        "recoverySteps": {
          "$ref": "#/$defs/stringArray"
        },
        "operatorRecoveryCommands": {
          "$ref": "#/$defs/operatorRecoveryCommands"
        },
        "diagnoseState": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ready",
            "degraded",
            "blocked",
            null
          ]
        },
        "safeToRequestCooling": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "daemonControlPathReady": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "manualControlActive": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "startupMode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Auto",
            "Curve",
            "Fixed",
            null
          ]
        },
        "daemonRuntime": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true,
          "description": "Raw guarded-run daemonRuntime payload when captured. For daemonRuntimeMismatch decisions, matchRequired should be true and matchesExpectedDaemon must not be true."
        },
        "failedCheckIDs": {
          "$ref": "#/$defs/stringArray"
        },
        "coolingBlockerIDs": {
          "$ref": "#/$defs/stringArray"
        },
        "requestedWorkload": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedDuration": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedMaxRPMPercent": {
          "type": [
            "integer",
            "null"
          ]
        },
        "reasonCharacterCount": {
          "type": [
            "integer",
            "null"
          ]
        },
        "childCommandName": {
          "type": [
            "string",
            "null"
          ]
        },
        "childCommandKind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "path",
            "pathLookup",
            null
          ]
        },
        "childArgumentCount": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "diagnoseDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitStatus",
        "state",
        "recommendedAgentAction",
        "recommendedRecoveryAction",
        "recoverySteps",
        "operatorRecoveryCommands",
        "safeToRequestCooling",
        "daemonControlPathReady",
        "manualControlActive",
        "failedCheckIDs",
        "coolingBlockerIDs",
        "appPreferences"
      ],
      "properties": {
        "exitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ready",
            "degraded",
            "blocked",
            null
          ]
        },
        "recommendedAgentAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "requestCooling",
            "requestCoolingWithCaution",
            "restoreAutoBeforeRequestingCooling",
            "doNotRequestCooling",
            null
          ]
        },
        "recommendedRecoveryAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "none",
            "repairHelper",
            "restoreAutoBeforeRetry",
            "backOffWorkload",
            "inspectPolicy",
            "collectHardwareEvidence",
            null
          ]
        },
        "recoverySteps": {
          "$ref": "#/$defs/stringArray"
        },
        "operatorRecoveryCommands": {
          "$ref": "#/$defs/operatorRecoveryCommands"
        },
        "safeToRequestCooling": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "daemonControlPathReady": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "manualControlActive": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "failedCheckIDs": {
          "$ref": "#/$defs/stringArray"
        },
        "coolingBlockerIDs": {
          "$ref": "#/$defs/stringArray"
        },
        "appPreferences": {
          "$ref": "#/$defs/appPreferencesDiagnostic"
        }
      }
    },
    "appPreferencesDiagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startupMode",
        "startupModeSource",
        "readError"
      ],
      "properties": {
        "startupMode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Auto",
            "Curve",
            "Fixed",
            null
          ]
        },
        "startupModeSource": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "persisted",
            "defaultMissingFile",
            "defaultMissingKey",
            "unreadable",
            "unavailable",
            null
          ]
        },
        "readError": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operatorRecoveryCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operatorRecoveryCommand"
      }
    },
    "operatorRecoveryCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "command",
        "workingDirectoryHint",
        "requiresUserApproval",
        "safeForAgentsToRunAutomatically",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "workingDirectoryHint": {
          "type": "string",
          "minLength": 1
        },
        "requiresUserApproval": {
          "const": true
        },
        "safeForAgentsToRunAutomatically": {
          "const": false
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
