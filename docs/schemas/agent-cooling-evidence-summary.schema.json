{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/agent-cooling-evidence-summary.schema.json",
  "title": "Vifty agent cooling evidence summary",
  "description": "Machine-readable summary written by scripts/collect-agent-cooling-evidence.sh for read-only agent/helper support bundles.",
  "type": "object",
  "required": [
    "schemaVersion",
    "schemaID",
    "generatedAtUTC",
    "readOnly",
    "coolingCommandsRun",
    "viftyctl",
    "auditLimit",
    "commands"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/agent-cooling-evidence-summary.schema.json"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "readOnly": {
      "const": true
    },
    "coolingCommandsRun": {
      "const": false
    },
    "viftyctl": {
      "type": "string"
    },
    "auditLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": [
        "name",
        "status",
        "stdout",
        "stderr",
        "statusFile"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "integer"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "statusFile": {
          "type": "string"
        }
      }
    }
  }
}
