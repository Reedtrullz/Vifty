{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/validation-review-result.schema.json",
  "title": "Vifty validation evidence review result",
  "description": "Machine-readable pass/fail summary emitted by scripts/review-validation-evidence.sh after reviewing a captured validation evidence bundle. Review results are read-only evidence and must not be used as proof that indexing or review ran cooling commands.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemaID",
    "generatedAtUTC",
    "status",
    "mode",
    "bundlePath",
    "readOnly",
    "coolingCommandsRun",
    "appPath",
    "releaseArtifactSummaryPath",
    "releaseChecklistPath",
    "installSource",
    "sourceRef",
    "sourceSHA",
    "sourceArtifactName",
    "sourceArtifactSHA256",
    "sourceArtifactBytes",
    "diagnoseState",
    "recommendedAgentAction",
    "recommendedRecoveryAction",
    "safeToRequestCooling",
    "daemonControlPathReady",
    "manualControlActive",
    "modelIdentifier",
    "modelFamily",
    "isAppleSilicon",
    "isMacBookPro",
    "fanCount",
    "controllableFanCount",
    "temperatureSensorCount",
    "thermalPressure",
    "manualSmokeTestResult",
    "manualSmokeTestSource",
    "agentRunSmokeResult",
    "agentRunSmokeSource",
    "failures",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/validation-review-result.schema.json"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "mode": {
      "$ref": "#/$defs/mode"
    },
    "bundlePath": {
      "type": "string",
      "description": "Share-safe evidence bundle directory name, not an absolute local filesystem path."
    },
    "readOnly": {
      "const": true
    },
    "coolingCommandsRun": {
      "const": false
    },
    "appPath": {
      "type": "string"
    },
    "releaseArtifactSummaryPath": {
      "type": "string"
    },
    "releaseChecklistPath": {
      "type": "string"
    },
    "installSource": {
      "$ref": "#/$defs/installSource"
    },
    "sourceRef": {
      "type": "string"
    },
    "sourceSHA": {
      "$ref": "#/$defs/gitSHA"
    },
    "sourceArtifactName": {
      "type": "string"
    },
    "sourceArtifactSHA256": {
      "$ref": "#/$defs/sha256"
    },
    "sourceArtifactBytes": {
      "type": "string",
      "pattern": "^([1-9][0-9]*)?$"
    },
    "diagnoseState": {
      "$ref": "#/$defs/nullableString"
    },
    "recommendedAgentAction": {
      "$ref": "#/$defs/nullableString"
    },
    "recommendedRecoveryAction": {
      "$ref": "#/$defs/nullableReadinessRecoveryAction"
    },
    "safeToRequestCooling": {
      "$ref": "#/$defs/nullableBoolean"
    },
    "daemonControlPathReady": {
      "$ref": "#/$defs/nullableBoolean"
    },
    "manualControlActive": {
      "$ref": "#/$defs/nullableBoolean",
      "description": "Whether viftyctl diagnose observed an active local/manual control marker at review time. Supported-hardware evidence should be false; null is reserved for legacy or failed summaries that did not capture the field."
    },
    "failedCheckIDs": {
      "$ref": "#/$defs/stringArray"
    },
    "coolingBlockerIDs": {
      "$ref": "#/$defs/stringArray"
    },
    "modelIdentifier": {
      "$ref": "#/$defs/nullableString"
    },
    "modelFamily": {
      "$ref": "#/$defs/nullableString",
      "description": "Stable model identifier prefix derived from modelIdentifier, for example MacBookPro18 from MacBookPro18,3. This is a grouping key, not a chip-generation claim."
    },
    "isAppleSilicon": {
      "$ref": "#/$defs/nullableBoolean"
    },
    "isMacBookPro": {
      "$ref": "#/$defs/nullableBoolean"
    },
    "fanCount": {
      "$ref": "#/$defs/nullableInteger"
    },
    "controllableFanCount": {
      "$ref": "#/$defs/nullableInteger"
    },
    "temperatureSensorCount": {
      "$ref": "#/$defs/nullableInteger"
    },
    "thermalPressure": {
      "$ref": "#/$defs/nullableString"
    },
    "manualSmokeTestResult": {
      "$ref": "#/$defs/manualSmokeTestResult"
    },
    "manualSmokeTestSource": {
      "type": "string"
    },
    "agentRunSmokeResult": {
      "$ref": "#/$defs/manualSmokeTestResult"
    },
    "agentRunSmokeSource": {
      "type": "string",
      "description": "Share-safe source reference for supervised agent-run smoke evidence, such as an issue URL or bundle-local summary path; auto-derived local filesystem paths should not be absolute."
    },
    "agentRunSmokeStartupMode": {
      "$ref": "#/$defs/agentRunSmokeStartupMode",
      "description": "Read-only startup mode copied from reviewed supervised agent-run smoke preflight app preferences when present. This is not a cooling authorization."
    },
    "agentRunSmokeStartupModeSource": {
      "$ref": "#/$defs/agentRunSmokeStartupModeSource",
      "description": "Read-only source for agentRunSmokeStartupMode copied from reviewed supervised agent-run smoke preflight app preferences when present."
    },
    "agentRunSmokeStartupModeReadError": {
      "type": "string",
      "description": "Read-only app-preferences diagnostic read error copied from reviewed supervised agent-run smoke preflight evidence when present."
    },
    "failures": {
      "$ref": "#/$defs/stringArray"
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "installSource": {
            "enum": [
              "source-build-tag",
              "source-first-unsigned-dev-zip",
              "local-ad-hoc-build"
            ]
          }
        },
        "required": [
          "installSource"
        ]
      },
      "then": {
        "properties": {
          "sourceSHA": {
            "$ref": "#/$defs/requiredGitSHA"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "installSource": {
            "enum": [
              "source-build-tag",
              "source-first-unsigned-dev-zip"
            ]
          }
        },
        "required": [
          "installSource"
        ]
      },
      "then": {
        "properties": {
          "sourceRef": {
            "$ref": "#/$defs/versionTag"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manualSmokeTestResult": {
            "const": "passed-auto-restored"
          }
        },
        "required": [
          "manualSmokeTestResult"
        ]
      },
      "then": {
        "properties": {
          "manualSmokeTestSource": {
            "$ref": "#/$defs/requiredNonEmptyString"
          }
        }
      }
    }
  ],
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableBoolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "agentRunSmokeStartupMode": {
      "enum": [
        "",
        "Auto",
        "Curve",
        "Fixed"
      ]
    },
    "agentRunSmokeStartupModeSource": {
      "enum": [
        "",
        "persisted",
        "defaultMissingFile",
        "defaultMissingKey",
        "unreadable",
        "unavailable"
      ]
    },
    "nullableInteger": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "enum": [
        "release",
        "supported-hardware",
        "unsupported-hardware"
      ]
    },
    "manualSmokeTestResult": {
      "enum": [
        "not-recorded",
        "passed-auto-restored",
        "skipped-blocked",
        "skipped-unsupported",
        "failed"
      ]
    },
    "installSource": {
      "enum": [
        "",
        "not-recorded",
        "source-build-tag",
        "source-first-unsigned-dev-zip",
        "notarized-github-release",
        "homebrew-cask",
        "local-developer-id-build",
        "local-ad-hoc-build",
        "other"
      ]
    },
    "readinessRecoveryAction": {
      "enum": [
        "none",
        "repairHelper",
        "restoreAutoBeforeRetry",
        "backOffWorkload",
        "inspectPolicy",
        "collectHardwareEvidence"
      ]
    },
    "nullableReadinessRecoveryAction": {
      "enum": [
        "none",
        "repairHelper",
        "restoreAutoBeforeRetry",
        "backOffWorkload",
        "inspectPolicy",
        "collectHardwareEvidence",
        null
      ]
    },
    "gitSHA": {
      "type": "string",
      "pattern": "^([0-9a-f]{40})?$"
    },
    "requiredGitSHA": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "requiredNonEmptyString": {
      "type": "string",
      "pattern": "\\S"
    },
    "versionTag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+([.-][0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^([0-9a-f]{64})?$"
    }
  }
}
