{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vifty.local/schemas/agent-run-smoke-evidence-summary.schema.json",
  "title": "Vifty agent run smoke evidence summary",
  "description": "Machine-readable summary written by scripts/collect-agent-run-smoke-evidence.sh for supervised viftyctl run smoke bundles.",
  "type": "object",
  "required": [
    "schemaVersion",
    "schemaID",
    "kind",
    "generatedAtUTC",
    "status",
    "readOnly",
    "coolingCommandsRun",
    "viftyctl",
    "installSource",
    "sourceRef",
    "sourceSHA",
    "sourceArtifactName",
    "sourceArtifactSHA256",
    "sourceArtifactBytes",
    "daemonRuntime",
    "workload",
    "duration",
    "maxRPMPercent",
    "reason",
    "auditLimit",
    "childCommand",
    "preflight",
    "run",
    "commands"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "schemaID": {
      "const": "https://vifty.local/schemas/agent-run-smoke-evidence-summary.schema.json"
    },
    "kind": {
      "const": "vifty-agent-run-smoke"
    },
    "generatedAtUTC": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "readOnly": {
      "type": "boolean"
    },
    "coolingCommandsRun": {
      "type": "boolean"
    },
    "viftyctl": {
      "type": "string"
    },
    "installSource": {
      "$ref": "#/$defs/installSource"
    },
    "sourceRef": {
      "type": "string"
    },
    "sourceSHA": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{40}$"
    },
    "sourceArtifactName": {
      "type": "string"
    },
    "sourceArtifactSHA256": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    },
    "sourceArtifactBytes": {
      "type": "string",
      "pattern": "^$|^[1-9][0-9]*$"
    },
    "daemonRuntime": {
      "$ref": "#/$defs/daemonRuntime"
    },
    "workload": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "maxRPMPercent": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "reason": {
      "type": "string"
    },
    "auditLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    },
    "childCommand": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "preflight": {
      "$ref": "#/$defs/preflight"
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "rateLimitRetry": {
      "$ref": "#/$defs/rateLimitRetry"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    }
  },
  "$defs": {
    "installSource": {
      "enum": [
        "not-recorded",
        "source-build-tag",
        "source-first-unsigned-dev-zip",
        "notarized-github-release",
        "homebrew-cask",
        "local-developer-id-build",
        "local-ad-hoc-build",
        "other"
      ]
    },
    "preflight": {
      "type": "object",
      "required": [
        "capabilitiesExitStatus",
        "capabilitiesSchemaVersion",
        "capabilitiesSchemaID",
        "diagnoseSchemaID",
        "commandErrorSchemaID",
        "runSchemaID",
        "resolvedChildExecutableReported",
        "daemonStatusAvailable",
        "policySource",
        "policyStatusAvailable",
        "policyEnabled",
        "exitStatus",
        "state",
        "recommendedAgentAction",
        "recommendedRecoveryAction",
        "safeToRequestCooling",
        "daemonControlPathReady",
        "manualControlActive"
      ],
      "properties": {
        "capabilitiesExitStatus": {
          "type": "integer"
        },
        "capabilitiesSchemaVersion": {
          "type": [
            "integer",
            "null"
          ]
        },
        "capabilitiesSchemaID": {
          "type": [
            "string",
            "null"
          ]
        },
        "diagnoseSchemaID": {
          "type": [
            "string",
            "null"
          ]
        },
        "commandErrorSchemaID": {
          "type": [
            "string",
            "null"
          ]
        },
        "runSchemaID": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolvedChildExecutableReported": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Copied from pre-capabilities runLifecycle.resolvedChildExecutableReported. When true, passed run proof must include run.resolvedChildExecutable."
        },
        "daemonStatusAvailable": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "policySource": {
          "type": [
            "string",
            "null"
          ]
        },
        "policyStatusAvailable": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "policyEnabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "exitStatus": {
          "type": "integer"
        },
        "state": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendedAgentAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendedRecoveryAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "safeToRequestCooling": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "daemonControlPathReady": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "manualControlActive": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "appPreferences": {
          "$ref": "#/$defs/appPreferencesDiagnostic"
        }
      }
    },
    "daemonRuntime": {
      "type": "object",
      "description": "Read-only provenance for the privileged daemon that actually services XPC during the smoke run. For current-build evidence, matchesExpectedDaemon must be true before cooling is requested.",
      "required": [
        "installedDaemonPath",
        "installedDaemonPresent",
        "installedDaemonSHA256",
        "expectedDaemonPath",
        "expectedDaemonSHA256",
        "matchesExpectedDaemon",
        "matchRequired"
      ],
      "properties": {
        "installedDaemonPath": {
          "type": "string"
        },
        "installedDaemonPresent": {
          "type": "boolean"
        },
        "installedDaemonSHA256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "expectedDaemonPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "expectedDaemonSHA256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "matchesExpectedDaemon": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "matchRequired": {
          "type": "boolean"
        }
      }
    },
    "appPreferencesDiagnostic": {
      "type": "object",
      "description": "Read-only app preference diagnostic copied from pre-diagnose; useful when manualControlActive blocks supervised smoke evidence, but never a cooling authorization.",
      "required": [
        "startupMode",
        "startupModeSource",
        "readError"
      ],
      "properties": {
        "startupMode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Auto",
            "Curve",
            "Fixed",
            null
          ]
        },
        "startupModeSource": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "persisted",
            "defaultMissingFile",
            "defaultMissingKey",
            "unreadable",
            "unavailable",
            null
          ]
        },
        "readError": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "run": {
      "type": "object",
      "required": [
        "exitStatus",
        "stdout",
        "stderr",
        "skippedReason",
        "schemaVersion",
        "schemaID",
        "command",
        "coolingLeasePrepared",
        "autoRestoreAttempted",
        "autoRestoreSucceeded",
        "childExitCode",
        "resolvedChildExecutable"
      ],
      "properties": {
        "exitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stdout": {
          "type": [
            "string",
            "null"
          ]
        },
        "stderr": {
          "type": [
            "string",
            "null"
          ]
        },
        "skippedReason": {
          "type": [
            "string",
            "null"
          ],
          "description": "Headline reason the collector skipped viftyctl run before cooling. Use skipReasons for the full ordered blocker list when present."
        },
        "skipReasons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ordered list of all known preflight blockers that caused the collector to skip viftyctl run before requesting cooling. Empty when run was attempted."
        },
        "schemaVersion": {
          "type": [
            "integer",
            "null"
          ]
        },
        "schemaID": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "coolingLeasePrepared": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "autoRestoreAttempted": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "autoRestoreSucceeded": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "childExitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "resolvedChildExecutable": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^/.*$",
          "description": "Absolute executable path copied from completed viftyctl run --json output when runLifecycle.resolvedChildExecutableReported is true."
        },
        "resolvedChildExecutableSHA256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$",
          "description": "Lowercase SHA-256 digest copied from completed viftyctl run --json output when the resolved executable file was readable."
        }
      }
    },
    "rateLimitRetry": {
      "type": "object",
      "required": [
        "attempted",
        "retryAfterSeconds",
        "initialExitStatus",
        "stdout",
        "stderr"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "retryAfterSeconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 300
        },
        "initialExitStatus": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stdout": {
          "type": [
            "string",
            "null"
          ]
        },
        "stderr": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "object",
      "required": [
        "name",
        "status",
        "stdout",
        "stderr",
        "statusFile"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "integer"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "statusFile": {
          "type": "string"
        }
      }
    }
  }
}
