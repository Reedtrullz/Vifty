{
  "commands": [
    "status",
    "capabilities",
    "diagnose",
    "audit",
    "prepare",
    "restore-auto",
    "run"
  ],
  "daemonStatusAvailable": true,
  "policyStatusAvailable": true,
  "agentControlStatusError": null,
  "exitCodes": {
    "blockedReadiness": 75,
    "commandFailure": 1,
    "success": 0,
    "unavailable": 69,
    "usage": 64
  },
  "policy": {
    "enabled": true,
    "maxDurationSeconds": 1800,
    "maximumAllowedRPMPercent": 80,
    "minimumAgentRPMPercent": 45,
    "prepareCooldownSeconds": 30
  },
  "policySource": "daemonStatus",
  "runLifecycle": {
    "autoRestoreAfterChildExit": true,
    "childCommandPreflightBeforeCooling": true,
    "cleanupStateReportedOnLaunchFailure": true,
    "signalsForwardedToChild": [
      "INT",
      "TERM",
      "HUP"
    ],
    "structuredPreChildFailures": true
  },
  "directControlLifecycle": {
    "prepareUsesIdempotencyKey": true,
    "preferRunForSingleChildWorkloads": true,
    "restoreAutoAcceptsIdempotencyKey": false,
    "restoreAutoScopedByIdempotencyKey": false
  },
  "metadataLimits": {
    "maximumIdempotencyKeyLength": 256,
    "maximumReasonLength": 512
  },
  "wrapperResources": {
    "bundleDirectory": "Contents/Resources/viftyctl-wrappers",
    "guardedRunScript": "guarded-run.sh",
    "sourceDirectory": "examples/viftyctl",
    "workloadScripts": [
      "cargo-build.sh",
      "cargo-test.sh",
      "custom-workload.sh",
      "local-model.sh",
      "make-build.sh",
      "make-test.sh",
      "make-verify.sh",
      "npm-build.sh",
      "npm-test.sh",
      "pytest.sh",
      "swift-release-build.sh",
      "swift-test.sh",
      "xcode-build.sh",
      "xcode-test.sh"
    ]
  },
  "schemaVersion": 1,
  "schemaIDs": {
    "audit": "https://vifty.local/schemas/viftyctl-audit.schema.json",
    "capabilities": "https://vifty.local/schemas/viftyctl-capabilities.schema.json",
    "commandError": "https://vifty.local/schemas/viftyctl-command-error.schema.json",
    "diagnose": "https://vifty.local/schemas/viftyctl-diagnose.schema.json",
    "status": "https://vifty.local/schemas/viftyctl-status.schema.json"
  },
  "schemaResources": {
    "audit": "Contents/Resources/schemas/viftyctl-audit.schema.json",
    "capabilities": "Contents/Resources/schemas/viftyctl-capabilities.schema.json",
    "commandError": "Contents/Resources/schemas/viftyctl-command-error.schema.json",
    "diagnose": "Contents/Resources/schemas/viftyctl-diagnose.schema.json",
    "status": "Contents/Resources/schemas/viftyctl-status.schema.json"
  },
  "schemas": {
    "audit": "docs/schemas/viftyctl-audit.schema.json",
    "capabilities": "docs/schemas/viftyctl-capabilities.schema.json",
    "commandError": "docs/schemas/viftyctl-command-error.schema.json",
    "diagnose": "docs/schemas/viftyctl-diagnose.schema.json",
    "status": "docs/schemas/viftyctl-status.schema.json"
  },
  "supportsForceRetry": true,
  "workloads": [
    "build",
    "test",
    "render",
    "localModel",
    "custom"
  ]
}
